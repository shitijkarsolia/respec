{
  "name": "respec-vscode",
  "displayName": "Respec — Visual Spec Review",
  "description": "Visual annotation layer for Kiro's spec-driven development. Three-column canvas with cross-linking, multi-agent validation, and structured feedback.",
  "version": "0.1.0",
  "publisher": "shitijkarsolia",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.kiro/specs"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "respec.openCanvas",
        "title": "Respec: Open Canvas"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "respec",
          "title": "Respec",
          "icon": "media/icon.svg"
        }
      ]
    }
  },
  "scripts": {
    "build:ext": "node esbuild.js",
    "build:webview": "cd webview && npm run build",
    "build": "npm run build:ext && npm run build:webview",
    "watch:ext": "node esbuild.js --watch",
    "package": "npm run build && vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.3.0"
  }
}
